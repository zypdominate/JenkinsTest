pipeline {
    agent {
        label 'win_label'
    }

    // 配置触发器 - 代码更新后自动触发
    triggers {
        // 轮询 SCM，检查代码变更（每2分钟检查一次，错开Linux流水线的触发时间）
        pollSCM('H/2 * * * *')
    }

    // 定义可配置的参数
    parameters {
        // 分支选择参数
        gitParameter(
            branch: '',
            name: 'BRANCH',
            description: '选择要测试的分支',
            type: 'PT_BRANCH',
            defaultValue: 'main',
            selectedValue: 'DEFAULT',
            sortMode: 'ASCENDING_SMART',
            quickFilterEnabled: true
        )

        // 测试目标参数 - 默认为所有单元测试
        string(
            name: 'TEST_TARGET',
            defaultValue: 'tests/',
            description: '测试目标路径（默认为 tests/ 目录下所有测试；也可以指定具体文件或测试用例）'
        )
    }

    stages {
        stage('Platform Detection') {
            steps {
                script {
                    echo "=== Windows Platform Pipeline ==="
                    echo "Node name: ${env.NODE_NAME}"
                    echo "Node labels: ${env.NODE_LABELS}"

                    env.CURRENT_PLATFORM = 'windows'
                    echo "Target platform: ${env.CURRENT_PLATFORM}"
                }
            }
        }

        stage('Get Git Info') {
            steps {
                script {
                    def gitCommit = ""
                    def gitMessage = ""
                    try {
                        echo "Getting Git info on Windows system"
                        gitCommit = bat(returnStdout: true, script: '@git rev-parse HEAD 2>nul').trim()

                        // Windows 下设置 UTF-8 编码获取 Git 提交信息
                        bat '''
                            @echo off
                            chcp 65001 > nul
                            git log -1 --pretty=format:"%%s" > git_message.tmp 2>nul
                        '''
                        gitMessage = readFile('git_message.tmp').trim()

                        echo "Current commit: ${gitCommit}"
                        echo "Commit message: ${gitMessage}"
                    } catch (Exception e) {
                        echo "Failed to get Git information: ${e.message}"
                        gitCommit = "unknown"
                        gitMessage = "No commit message"
                    }

                    env.GIT_COMMIT_SHORT = gitCommit.length() > 7 ? gitCommit.take(7) : gitCommit
                    env.GIT_COMMIT_MESSAGE = gitMessage
                }
            }
        }

        stage('Set Build Name') {
            steps {
                script {
                    def user = currentBuild.rawBuild.getCause(hudson.model.Cause$UserIdCause)?.userId ?: "Auto-Trigger"
                    echo "Triggered by user: ${user}"

                    def branch_name = params.BRANCH ?: (env.GIT_BRANCH ? env.GIT_BRANCH.split('/').last() : 'main')
                    if (params.BRANCH) {
                        branch_name = params.BRANCH
                        if (branch_name.startsWith('refs/heads/')) {
                            branch_name = branch_name.substring(11)
                        }
                    } else if (env.GIT_BRANCH) {
                        def branchParts = env.GIT_BRANCH.split('/')
                        branch_name = branchParts[-1]
                    }

                    currentBuild.displayName = "#${BUILD_NUMBER}-Windows-${branch_name}-${env.GIT_COMMIT_SHORT}-${user}"
                    currentBuild.description = "Platform: Windows | Branch: ${branch_name} | Commit: ${env.GIT_COMMIT_MESSAGE}"

                    echo "Branch: ${branch_name}"
                    echo "Platform: Windows"
                    echo "Trigger method: ${user}"
                }
            }
        }

        stage('Setup Windows Environment') {
            steps {
                script {
                    echo "=== Setting up Windows environment ==="

                    bat '''
                        echo Checking Python environment on Windows...
                        where python
                        python --version

                        echo Getting virtual environment activation script path...
                        python -c "import os, sys; print(os.path.join(os.path.dirname(sys.executable), 'Scripts', 'activate.bat'), end='')" > activate_path.txt
                        type activate_path.txt

                        echo Checking test directory:
                        if exist tests (
                            echo tests directory exists
                            dir tests
                        ) else (
                            echo Warning: tests directory does not exist!
                        )
                    '''
                }
            }
        }

        stage('Run Unit Tests on Windows') {
            steps {
                script {
                    echo "=== Running unit tests on Windows ==="

                    bat '''
                        echo Cleaning previous test results...
                        if exist allure-results rmdir /s /q allure-results
                        mkdir allure-results
                    '''

                    def reportCommand = "--alluredir=allure-results"

                    try {
                        bat '''
                            echo Starting unit tests on Windows...
                            set /p ACTIVATE_PATH=<activate_path.txt
                            call "%ACTIVATE_PATH%" envPy3.12
                            python --version
                            python -m pytest ''' + params.TEST_TARGET + ''' -v -s ''' + reportCommand + '''
                        '''

                        currentBuild.result = 'SUCCESS'
                        echo "Unit tests executed successfully on Windows!"

                    } catch (Exception e) {
                        currentBuild.result = 'UNSTABLE'
                        echo "Unit tests have failed test cases on Windows: ${e.message}"
                        // 即使测试失败，也继续执行后续步骤以生成报告
                    }
                }
            }
            post {
                always {
                    script {
                        // 发布测试报告
                        if (fileExists('allure-results')) {
                            allure results: [[path: 'allure-results']]
                        }
                    }
                }
            }
        }
    }

    options {
        // 保留构建日志的策略
        buildDiscarder(logRotator(numToKeepStr: '100', artifactNumToKeepStr: '50'))
        // 超时处理
        timeout(time: 60, unit: 'MINUTES')
        // 跳过默认的 checkout
        skipDefaultCheckout(false)
        // 时间戳
        timestamps()
    }

    // 构建后通知
    post {
        success {
            echo "Windows unit tests executed successfully! All test cases passed."
        }
        unstable {
            echo "Windows unit tests completed, but some test cases failed. Please check the test report."
        }
        failure {
            echo "Windows unit test execution failed. Please check build logs and test reports."
        }
        always {
            echo "Windows build completed, cleaning up temporary files..."
            bat '''
                if exist activate_path.txt del activate_path.txt
                if exist git_message.tmp del git_message.tmp
            '''
        }
    }
}